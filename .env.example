# 仅需通过环境变量配置数据库连接地址与基础元信息，其余配置项通过数据库存储，可由前端 API 修改。
# 数据库连接字符串（默认 SQLite 本地文件）
CHAT_GUARDIAN_DATABASE_URL=sqlite:///./db.sqlite
# 应用名称（只读，显示用途）
CHAT_GUARDIAN_APP_NAME=ChatGuardian
# 运行环境标识（只读，如 dev/prod，可用于日志/CORS 等只读逻辑）
CHAT_GUARDIAN_ENVIRONMENT=dev
# 如需预配置管理员账号，可通过以下环境变量写入数据库；默认无账号密码，需首次启动在引导页创建。
# CHAT_GUARDIAN_ADMIN_USERNAME=
# CHAT_GUARDIAN_ADMIN_PASSWORD=
